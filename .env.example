# NextAuth Secrets
AUTH_SECRET="your-super-secret-key-at-least-32-chars-long"
NEXTAUTH_URL="http://localhost:3000"

# Microsoft Entra ID (Outlook Integration)
MICROSOFT_CLIENT_ID="your-client-id"
MICROSOFT_CLIENT_SECRET="your-client-secret"
MICROSOFT_TENANT_ID="your-tenant-id"
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/auth/callback/microsoft-entra-id"

# Scheduled Jobs
CRON_SECRET="replace-with-a-long-random-secret"
ENABLE_CRON="false"

# i18n
DEFAULT_LOCALE="es"
SUPPORTED_LOCALES="es"

# AI
ANTHROPIC_API_KEY=""

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_ACCOUNT_KEY=""
AZURE_STORAGE_CONTAINER="cvs"
